# OctoFit Tracker Frontend Environment Variables Template
# 
# Copy this file to .env.local and update the values for your environment
#
# Required for Codespaces deployment:
# - Set VITE_CODESPACE_NAME to your Codespace name
# 
# For local development:
# - Leave VITE_CODESPACE_NAME unset or set to empty string

# Your Codespace name (obtain from GitHub Codespaces settings)
# Leave empty for localhost development
VITE_CODESPACE_NAME=
